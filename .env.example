# Copia questo file in `.env` e adatta i valori al tuo ambiente.

# Connessione MongoDB del backend.
# NOTA: al momento la connessione Mongoose è commentata in
# apps/backend/src/app/app.module.ts — questa variabile verrà usata
# solo quando il blocco MongooseModule sarà decommentato.
MONGODB_URI=mongodb://localhost:27017/crosstitch

# Porta del backend NestJS
PORT=3000
